# Supabase — crie um novo projeto em supabase.com e cole as chaves aqui
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Mercado Pago — crie um app em developers.mercadopago.com.br
MP_CLIENT_ID=seu-client-id
MP_CLIENT_SECRET=seu-client-secret
MP_ACCESS_TOKEN=seu-access-token-de-producao
MP_REDIRECT_URI=https://seu-dominio.com/admin/mp-callback

# Exposto no cliente (usado pelo AdminConfiguracoes para o OAuth link)
VITE_MP_CLIENT_ID=seu-client-id
VITE_MP_REDIRECT_URI=https://seu-dominio.com/admin/mp-callback

# URL base do app (usada nos back_urls do MP e no webhook)
PUBLIC_URL=https://trilheiros.app
WEBHOOK_BASE_URL=https://trilheiros.app

# Resend (e-mails transacionais)
RESEND_API_KEY=re_xxxxxxxxxxxxx
